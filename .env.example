# Email SMTP configuration
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# File paths (optional)
RESUME_FILE=resume.json
TRACKING_FILE=email_tracking.json
GENERATED_EMAILS_FILE=generated_emails.json