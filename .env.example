# Google Gemini configuration
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-1.5-flash

# Candidate profile and customization
TARGET_INTERNSHIP_START=fevrier 2026
SENDER_NAME=Your Full Name
